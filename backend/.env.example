# ────────────────────────────────────────────────────────
#  Neural ERP — environment template
# ────────────────────────────────────────────────────────
#  Copy this file to `.env` for shared dev defaults, then
#  override secrets in `.env.local` (gitignored, takes priority).
#
#  Generate JWT secrets with:
#    node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ────────────────────────────────────────────────────────

# ─── Database (required) ─────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/neural_erp

# ─── JWT (required) ──────────────────────────────────────
JWT_SECRET=generate-a-256-bit-random-secret
JWT_REFRESH_SECRET=generate-a-different-256-bit-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OTP / Email (optional — dev falls back to console log) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Service Ports ───────────────────────────────────────
PORT=3000
AUTH_SERVICE_PORT=3001
ACADEMIC_SERVICE_PORT=3002
ATTENDANCE_SERVICE_PORT=3003
TIMETABLE_SERVICE_PORT=3004
ASSIGNMENT_SERVICE_PORT=3005
GRADE_SERVICE_PORT=3006
CAREER_SERVICE_PORT=3007
NOTES_SERVICE_PORT=3008
FEE_SERVICE_PORT=3009
LIBRARY_SERVICE_PORT=3010
FORUM_SERVICE_PORT=3011
NOTIFICATION_SERVICE_PORT=3012
ADMIN_SERVICE_PORT=3013
ML_SERVICE_PORT=3014

# ─── Service URLs (for API Gateway) ──────────────────────
AUTH_SERVICE_URL=http://localhost:3001
ACADEMIC_SERVICE_URL=http://localhost:3002
ATTENDANCE_SERVICE_URL=http://localhost:3003
TIMETABLE_SERVICE_URL=http://localhost:3004
ASSIGNMENT_SERVICE_URL=http://localhost:3005
GRADE_SERVICE_URL=http://localhost:3006
CAREER_SERVICE_URL=http://localhost:3007
NOTES_SERVICE_URL=http://localhost:3008
FEE_SERVICE_URL=http://localhost:3009
LIBRARY_SERVICE_URL=http://localhost:3010
FORUM_SERVICE_URL=http://localhost:3011
NOTIFICATION_SERVICE_URL=http://localhost:3012
ADMIN_SERVICE_URL=http://localhost:3013
ML_SERVICE_URL=http://localhost:3014

# ─── Frontend ────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Infra ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Error Alerting (optional) ───────────────────────────
ERROR_WEBHOOK_URL=

# ─── Environment ─────────────────────────────────────────
NODE_ENV=development

# ─── AI Career Recommendations ──────────────────────────
# CAREER_AI_MODE=demo  → rule-based scoring on local CareerOpportunity rows.
#                       No external calls. Default. Safe for any environment.
# CAREER_AI_MODE=live  → real Gemini API (requires GEMINI_API_KEY below).
#                       Falls back to demo on Gemini failure.
CAREER_AI_MODE=demo
GEMINI_API_KEY=

# ─── ML Service (Python FastAPI) ────────────────────────
# ML_DATA_MODE=demo → predictions from synthetic-trained model (no live DB read).
#                    Default. Anyone cloning this repo gets working AI.
# ML_DATA_MODE=live → predictions from features assembled out of live DB rows.
#                    Requires DATABASE_URL to be readable from ml-service.
ML_DATA_MODE=demo
ML_MODEL_DIR=/app/models

# Shared secret guarding ml-service /train and /predict/batch.
# admin-service forwards this in the X-ML-Admin-Token header.
ML_ADMIN_TOKEN=change-me-shared-secret
