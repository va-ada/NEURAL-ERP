# ────────────────────────────────────────────────────────
#  Neural ERP — local secret overrides
# ────────────────────────────────────────────────────────
#  Copy to `.env.local` and fill in real values.
#  .env.local is gitignored and takes priority over .env.
# ────────────────────────────────────────────────────────

# Rotated Gemini API key (paste after rotating at console.cloud.google.com)
GEMINI_API_KEY=

# Real SMTP credentials (only needed if you want emailed OTPs instead of console logs)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Override DB password if you changed the Postgres container's password
# DATABASE_URL=postgresql://neural_admin:NEW_PASSWORD@localhost:5432/neural_erp

# Error webhook for production-like alerts
# ERROR_WEBHOOK_URL=https://hooks.slack.com/services/...
