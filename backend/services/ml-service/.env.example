# ─── ML Service Environment Template ──────────────────────
# Copy to .env for local dev. Container reads the parent backend/.env.

# demo  → train + predict on synthetic CSV. No DB required.
# live  → assemble feature vectors from the live Postgres tables.
ML_DATA_MODE=demo

# Required when ML_DATA_MODE=live. If unset/unreachable, service falls back to demo.
DATABASE_URL=

# Where joblib model artefacts are written/loaded.
ML_MODEL_DIR=./models

# Shared secret guarding /train and /predict/batch.
ML_ADMIN_TOKEN=change-me-shared-secret

# Service port (mirrors backend/.env).
ML_SERVICE_PORT=3014
