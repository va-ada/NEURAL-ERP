# API gateway base URL
VITE_API_URL=http://localhost:3000

# ────────────────────────────────────────────────────────
#  Dev-only mock login (optional)
# ────────────────────────────────────────────────────────
#  Setting this enables the dev-mode quick-login grid + the
#  mock fallback path in AuthContext when the backend is
#  unreachable. Leave empty (or remove) to disable.
#
#  Production builds (vite build --mode production) ignore
#  this entirely, so mock auth can never ship to users.
VITE_DEV_PASSWORD=
